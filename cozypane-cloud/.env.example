DATABASE_URL=postgresql://cozypane:secret@postgres:5432/cozypane
POSTGRES_PASSWORD=secret
JWT_SECRET=change-me-to-random-string
# AES-256-GCM key used to encrypt GitHub access tokens at rest in users.access_token.
# Generate with: openssl rand -hex 32
# This MUST be set in production — /auth/github will 500 if it's missing.
# If you rotate this value, every existing user will need to re-authenticate.
GITHUB_TOKEN_ENCRYPTION_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_GITHUB_CLIENT_ID=
ADMIN_GITHUB_CLIENT_SECRET=
CF_API_EMAIL=you@example.com
CF_API_KEY=
DOMAIN=yourdomain.com
ACME_EMAIL=you@example.com

# M23: BullMQ deploy queue settings.
# REDIS_URL — defaults to the in-network redis:6379/0 service from
#   docker-compose. Override only if pointing at an external Redis.
# DEPLOY_QUEUE_CONCURRENCY — max simultaneous builds per worker process.
#   Default 4. Raise carefully; each build can consume ~1-2 GB RAM and
#   several CPU cores for the docker build step.
REDIS_URL=redis://redis:6379/0
DEPLOY_QUEUE_CONCURRENCY=4
